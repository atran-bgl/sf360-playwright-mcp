# SF360 Playwright MCP - Environment Configuration
# Copy this file to .env and fill in your actual credentials

# ===== Environment Selection =====
# Which environment to test against
# Options: uat, staging, production
ENVIRONMENT=uat

# ===== User Credentials =====
# Your BGL email for authentication
USERNAME=your.email@bglcorp.com.au

# Your password
USER_PASSWORD=your_password_here

# TOTP/2FA Secret (base32 encoded, from authenticator app)
# Required for automatic TOTP generation
# Get this from your authenticator app during initial 2FA setup
TOTP_SECRET=YOUR_TOTP_SECRET_KEY_HERE

# ===== SF360 Configuration =====
# User ID (numeric)
UID=your_user_id

# Default firm to use for tests
FIRM=sf360test

# ===== AWS Configuration =====
# IMPORTANT: This package fetches environment-specific configuration from AWS Parameter Store:
#
# The following are automatically fetched from AWS SSM (no need to set in .env):
# - COGNITO_URL (from /${ENVIRONMENT}/sf360/test-automation/aws-cognito/ADDRESS)
# - COGNITO_CLIENT_ID (from /${ENVIRONMENT}/sf360/test-automation/aws-cognito/ID)
# - SSO_URL (from /${ENVIRONMENT}/sf360/test-automation/sso/ADDRESS)
# - SF360_SERVER_URL (from /${ENVIRONMENT}/sf360/test-automation/server/ADDRESS)
#
# Prerequisites:
# 1. AWS CLI configured: run `aws configure`
# 2. AWS credentials with SSM:GetParameters permission
# 3. Access to BGL AWS account (ap-southeast-2 region)
#
# If you don't have AWS access, contact your BGL administrator.

# ===== Alternative Login (for users without AWS access) =====
# If AWS authentication fails, setupTest() will automatically fall back to UI-based login.
# Uncomment this line to enable the fallback:
# 360_UAT_URL=https://sso.uat.bgl360.com.au/login/?app=sf360
#
# Note: UI-based login is slower (10-15s) compared to API-based (2-3s) but works
# without AWS credentials. The system will try AWS first, then fall back automatically.
