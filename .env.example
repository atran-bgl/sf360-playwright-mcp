# SF360 UAT Credentials
# Copy this file to .env and fill in your actual credentials

# User credentials
USERNAME=your.email@bglcorp.com.au
USER_PW=your_password_here

# TOTP/2FA Secret (from authenticator app)
# Optional: Omit this or leave empty to enter OTP manually during test run
# Note: Requires 'otplib' package for automatic TOTP generation (npm install otplib)
TOTP_SECRET=YOUR_TOTP_SECRET_KEY_HERE

# Default firm to select after login
FIRM=sf360test

# UAT URL
360_UAT_URL=https://sso.uat.bgl360.com.au/login/?app=sf360
