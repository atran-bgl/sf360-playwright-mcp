    },
    "screenshotsAvailable": [
      ".playwright-mcp/discoveries/workflow_entities/screenshot/main.png",
      ".playwright-mcp/discoveries/workflow_entities/screenshot/full-page.png"
    ],
    "elementsInventory": ".playwright-mcp/discoveries/workflow_entities/elements.json"
  },
  "notes": [
    "Search is real-time - filters update as user types",
    "Search is case-insensitive",
    "Search matches both entity code and entity name",
    "No dedicated 'no results' message - table just shows 0 rows",
    "May need to adjust wait times if search has debouncing",
    "Known test data from discovery: ERICNEWC8529 (Eric New Company), ERICNEWS8542 (Eric New SMSF)",
    "Test uses existing entities - no test data creation needed"
  ]
